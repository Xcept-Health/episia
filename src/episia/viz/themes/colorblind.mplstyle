# episia: colorblind
figure.facecolor : white
axes.facecolor   : white
axes.linewidth   : 0.8
axes.grid        : True
axes.spines.top  : False
axes.spines.right: False
grid.linewidth   : 0.5
font.family      : sans-serif
font.size        : 11
axes.titlesize   : 13
axes.labelsize   : 11
xtick.labelsize  : 10
ytick.labelsize  : 10
legend.frameon   : False
figure.dpi       : 100
